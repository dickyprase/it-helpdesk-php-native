# Block PHP execution
<FilesMatch "\.(php|phtml|phar|php3|php4|php5|php7|phps|cgi|pl|asp|aspx|jsp|sh|bash)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>
php_flag engine off
